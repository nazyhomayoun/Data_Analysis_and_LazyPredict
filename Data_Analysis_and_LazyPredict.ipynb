    "# Cost Sensitivity Implementation\n",
    "from sklearn.utils.class_weight import compute_class_weight\n",
    "\n",
    "# Compute class weights\n",
    "class_weights = compute_class_weight(\n",
    "    class_weight='balanced',\n",
    "    classes=np.unique(y_train),\n",
    "    y=y_train\n",
    ")\n",
    "\n",
    "# Create a dictionary for class weights\n",
    "class_weight_dict = {i: weight for i, weight in enumerate(class_weights)}\n",
    "\n",
    "# Train a RandomForest with class weights\n",
    "cost_sensitive_rf = RandomForestClassifier(class_weight=class_weight_dict, random_state=42)\n",
    "cost_sensitive_rf.fit(X_train, y_train)\n",
    "\n",
    "# Predictions and evaluation\n",
    "y_pred_cs = cost_sensitive_rf.predict(X_test)\n",
    "\n",
    "# Evaluation metrics\n",
    "print(\"\\nCost-Sensitive Model Evaluation:\")\n",
    "print(\"Confusion Matrix:\")\n",
    "print(confusion_matrix(y_test, y_pred_cs))\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_test, y_pred_cs))\n",
    "\n",
    "# Add multi_class parameter for multiclass cases\n",
    "print(f\"ROC AUC Score: {roc_auc_score(y_test, cost_sensitive_rf.predict_proba(X_test), multi_class='ovr')}\")\n",
    "print(f\"Accuracy: {accuracy_score(y_test, y_pred_cs)}\")\n"
