    "# Check if 'Label' column exists in the dataset\n",
    "if 'Label' in data.columns:\n",
    "    print(\"\\nStarting Train-Test Split and Model Evaluation:\\n\")\n",
    "\n",
    "    # Separate features (X) and target (y)\n",
    "    X = data.drop('Label', axis=1)\n",
    "    y = data['Label']\n",
    "\n",
    "    # Check for missing values and handle them (if any)\n",
    "    if X.isnull().sum().sum() > 0:\n",
    "        print(\"Warning: Missing values detected in features. Filling with mean.\")\n",
    "        X = X.fillna(X.mean())\n",
    "    if y.isnull().sum() > 0:\n",
    "        print(\"Warning: Missing values detected in target. Filling with mode.\")\n",
    "        y = y.fillna(y.mode()[0])\n",
    "\n",
    "    # Ensure all features are numeric (encode if necessary)\n",
    "    if not all(X.dtypes.apply(lambda dtype: dtype.kind in 'biufc')):\n",
    "        print(\"Warning: Non-numeric features detected. Encoding them.\")\n",
    "        X = pd.get_dummies(X)\n",
    "\n",
    "    # Split the data into training and testing sets\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X, y, test_size=0.3, random_state=42, stratify=y\n",
    "    )\n",
    "\n",
    "    # Evaluate models using LazyClassifier\n",
    "    print(\"\\nEvaluating Models with LazyPredict:\\n\")\n",
    "    clf = LazyClassifier(verbose=0, ignore_warnings=True, custom_metric=None)\n",
    "    models, predictions = clf.fit(X_train, X_test, y_train, y_test)\n",
    "    print(models)\n",
    "\n",
    "    # Save model evaluation results to a CSV file\n",
    "    models.to_csv('model_evaluation_results.csv', index=True)\n",
    "    print(\"Model evaluation results saved as 'model_evaluation_results.csv'\")\n",
    "else:\n",
    "    print(\"Error: 'Label' column not found in the dataset. Please check your data.\")\n",
    "\n",
    "# Save preprocessed data to a CSV file\n",
    "print(\"\\nSaving Preprocessed Data:\\n\")\n",
    "data.info()\n",
    "data.to_csv('preprocessed_data.csv', index=False)\n",
    "print(\"Preprocessed data saved as 'preprocessed_data.csv'\")\n"
   ]
